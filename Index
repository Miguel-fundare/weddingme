<script>
(function(){
  const ANSWER = 2; // Cappadocia — CHANGE IF NEEDED
  const msgs = {
    en: {
      correct: "🎉 You got it! The real proposal was in Cappadocia at sunrise, surrounded by hundreds of hot air balloons. She said yes before he finished asking.",
      wrong: {
        1: "❄️ Beautiful guess — but Central Park was just a winter walk. The real moment had a much more dramatic backdrop!",
        3: "🛒 Ha! Give Miguel credit for creativity... but no. Though the hot dogs are $1.50.",
        4: "💙 The Tiffany box is real — but the actual proposal happened somewhere far more cinematic!"
      }
    },
    ru: {
      correct: "🎉 Правильно! Настоящее предложение было в Каппадокии на рассвете, в окружении сотен воздушных шаров. Она сказала «да», не дав ему договорить.",
      wrong: {
        1: "❄️ Красивая попытка — но Центральный парк был просто прогулкой. Настоящий момент был куда более кинематографичным!",
        3: "🛒 Ха! Уважаем оригинальность... но нет. Хотя хот-доги там за $1.50.",
        4: "💙 Коробочка Tiffany настоящая — но само предложение произошло в куда более эпичном месте!"
      }
    }
  };
  let sel=null, voted=false;
  let gvotes={1:14,2:9,3:38,4:11};

  window.gVote = function(n){
    if(voted) return;
    sel=n;
    document.querySelectorAll('.g-card').forEach(c=>c.classList.remove('selected'));
    document.getElementById('gc-'+n).classList.add('selected');
    document.getElementById('g-vote-btn').disabled=false;
  };

  window.gSubmit = function(){
    if(!sel||voted) return;
    voted=true; gvotes[sel]++;
    const total=Object.values(gvotes).reduce((a,b)=>a+b,0);
    for(let i=1;i<=4;i++){
      const pct=Math.round(gvotes[i]/total*100);
      document.getElementById('gb-'+i).style.display='block';
      document.getElementById('gp-'+i).style.display='block';
      document.getElementById('gp-'+i).textContent=pct+'%';
      setTimeout(()=>{document.getElementById('gf-'+i).style.width=pct+'%';},120);
      const card=document.getElementById('gc-'+i);
      card.style.cursor='default';
      if(i===ANSWER){
        card.classList.add('correct');
        document.getElementById('gbdg-'+i).textContent='✅';
        document.getElementById('gbdg-'+i).style.display='block';
      } else if(i===sel&&i!==ANSWER){
        card.classList.add('wrong');
        document.getElementById('gbdg-'+i).textContent='❌';
        document.getElementById('gbdg-'+i).style.display='block';
      }
    }
    document.getElementById('g-actions').style.display='none';
    document.getElementById('g-reveal').style.display='block';
    document.getElementById('g-total').textContent=total;
    document.getElementById('g-cpct').textContent=Math.round(gvotes[ANSWER]/total*100)+'%';
    const lang=document.body.classList.contains('lang-ru')?'ru':'en';
    const m=msgs[lang];
    document.getElementById('g-rmsg').textContent=sel===ANSWER?m.correct:(m.wrong[sel]||'Not quite!');
  };
})();
</script>

