/* ── SETUP ───────────────────────────────────────────── */
const cvs = document.getElementById('ci-canvas');
const ctx = cvs.getContext('2d');
let W, H;
function resize(){
  const rect = cvs.getBoundingClientRect();
  W = cvs.width  = rect.width  || window.innerWidth  || document.documentElement.clientWidth  || 800;
  H = cvs.height = rect.height || window.innerHeight || document.documentElement.clientHeight || 600;
}
window.addEventListener('resize', resize); resize();

function proj(lat,lon){ return [(lon+180)/360*W, (90-lat)/180*H]; }

/* ── EASING ─────────────────────────────────────────── */
function eio(t){ return t<0.5?2*t*t:-1+(4-2*t)*t; }
function clamp(v,a,b){ return Math.max(a,Math.min(b,v)); }

/* ── PATH INTERPOLATION ─────────────────────────────── */
function getPosOnPath(path, t){
  const start=path[0][2], end=path[path.length-1][2];
  if(t<=start) return {lat:path[0][0],lon:path[0][1],segIdx:0};
  if(t>=end)   return {lat:path[path.length-1][0],lon:path[path.length-1][1],segIdx:path.length-1};
  for(let i=0;i<path.length-1;i++){
    const ta=path[i][2],tb=path[i+1][2];
    if(t>=ta&&t<=tb){
      const f=eio(clamp((t-ta)/(tb-ta),0,1));
      let dlon=path[i+1][1]-path[i][1];
      if(dlon>180) dlon-=360; if(dlon<-180) dlon+=360;
      return {lat:path[i][0]+(path[i+1][0]-path[i][0])*f, lon:path[i][1]+dlon*f,
              segIdx:i, label:i<path.length-2?path[i+1][3]:null, progress:f};
    }
  }
  return {lat:path[path.length-1][0],lon:path[path.length-1][1]};
}

/* ── DRAW COUNTRY ────────────────────────────────────── */
function drawCountry(pts, col, alpha, glowColor){
  if(alpha<=0) return;
  const coords = pts.map(([lat,lon])=>proj(lat,lon));

  // glow shadow
  ctx.save();
  ctx.shadowColor = glowColor;
  ctx.shadowBlur = 18;
  ctx.beginPath();
  coords.forEach(([x,y],i)=>i===0?ctx.moveTo(x,y):ctx.lineTo(x,y));
  ctx.closePath();
  ctx.strokeStyle = `rgba(${col},${alpha})`;
  ctx.lineWidth = 1.2;
  ctx.stroke();

  // fill with very subtle tint
  ctx.beginPath();
  coords.forEach(([x,y],i)=>i===0?ctx.moveTo(x,y):ctx.lineTo(x,y));
  ctx.closePath();
  ctx.fillStyle = `rgba(${col},${alpha*0.07})`;
  ctx.fill();
  ctx.restore();
}

/* ── GLOW ────────────────────────────────────────────── */
function drawGlow(x,y,r,col,alpha){
  const g=ctx.createRadialGradient(x,y,0,x,y,r);
  g.addColorStop(0,`rgba(${col},${alpha})`);
  g.addColorStop(0.3,`rgba(${col},${alpha*0.55})`);
  g.addColorStop(1,`rgba(${col},0)`);
  ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2);
  ctx.fillStyle=g; ctx.fill();
}

/* ── AMBIENT PARTICLES ───────────────────────────────── */
const PARTS=Array.from({length:90},()=>({
