<script>
// PASSWORD
const PW = "boda2026";
function checkPw() {
  const v = document.getElementById('pw-input').value.trim().toLowerCase();
  if (v === PW) {
    const s = document.getElementById('password-screen');
    s.classList.add('hidden');
    setTimeout(() => {
      s.style.display = 'none';
      const intro = document.getElementById('cinematic-intro');
      intro.style.display = 'block';
      if (window.startCinematicIntro) window.startCinematicIntro();
    }, 700);
  } else {
    const e = document.getElementById('pw-error');
    e.classList.add('show');
    setTimeout(() => e.classList.remove('show'), 2500);
  }
}
document.getElementById('pw-input').addEventListener('keydown', e => { if (e.key === 'Enter') checkPw(); });

// LANGUAGE
function setLang(l) {
  document.body.className = l === 'ru' ? 'lang-ru' : '';
  document.querySelectorAll('.lang-btn').forEach((b,i) => b.classList.toggle('active', (l==='en'&&i===0)||(l==='ru'&&i===1)));
}

// COUNTDOWN — change date here
const wDate = new Date('2026-11-10T16:00:00');
document.getElementById('hero-date-txt').textContent =
  wDate.toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) + ' · Mexico';

function tick() {
  const diff = wDate - new Date();
  if (diff <= 0) return;
  const d = Math.floor(diff/86400000);
  const h = Math.floor((diff%86400000)/3600000);
  const m = Math.floor((diff%3600000)/60000);
  const s = Math.floor((diff%60000)/1000);
  document.getElementById('cd-d').textContent = String(d).padStart(3,'0');
  document.getElementById('cd-h').textContent = String(h).padStart(2,'0');
  document.getElementById('cd-m').textContent = String(m).padStart(2,'0');
  document.getElementById('cd-s').textContent = String(s).padStart(2,'0');
}
tick(); setInterval(tick, 1000);

// SCROLL ANIMATIONS
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('vis'); obs.unobserve(e.target); } });
}, { threshold: 0.1 });
document.querySelectorAll('.fi').forEach(el => obs.observe(el));

// RSVP
function submitRsvp() {
  const fn = document.getElementById('r-fn').value.trim();
  const em = document.getElementById('r-em').value.trim();
  if (!fn || !em) {
    alert(document.body.classList.contains('lang-ru')
      ? 'Пожалуйста, заполните имя и email.'
      : 'Please fill in your name and email.');
    return;
  }
  document.getElementById('rsvp-form').style.display = 'none';
  document.getElementById('rsvp-ok').style.display = 'block';
}

// SMOOTH SCROLL
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    document.querySelector(a.getAttribute('href'))?.scrollIntoView({behavior:'smooth'});
  });
});
</script>

