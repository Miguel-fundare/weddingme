  a:Math.random(),va:(Math.random()-0.5)*0.003,
  vx:(Math.random()-0.5)*0.0002,vy:(Math.random()-0.5)*0.0001,
}));

const TRAIL_LEN=100;
let trail1=[],trail2=[];
let merged=false, mergeT=0;
let startTime=null, introEnded=false, mapAlpha=0;
let showed1979=false,showed1990=false,showedAustin=false,showedSeren=false,showedFinale=false;
let cityLblTimer=0, lastCity='';
let mexicoAlpha=0, russiaAlpha=0;

/* ── TEXT HELPERS ─────────────────────────────────────── */
function showEl(id){ const e=document.getElementById(id); if(e) e.classList.add('on'); }
function hideEl(id){ const e=document.getElementById(id); if(e) e.classList.remove('on'); }

/* ── MAIN LOOP ───────────────────────────────────────── */
function animate(ts){
  if(introEnded) return;
  if(!startTime) startTime=ts;
  const t=(ts-startTime)/1000;

  ctx.clearRect(0,0,W,H);

  // Background
  const bg=ctx.createRadialGradient(W/2,H/2,0,W/2,H/2,Math.max(W,H)*0.85);
  bg.addColorStop(0,'#06101f'); bg.addColorStop(1,'#000408');
  ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);

  mapAlpha=clamp(t/2.2,0,0.9);

  // Ambient particles
  PARTS.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy; p.a+=p.va;
    if(p.x<0)p.x=1; if(p.x>1)p.x=0;
    if(p.y<0)p.y=1; if(p.y>1)p.y=0;
    if(p.a<0||p.a>1){p.va*=-1;} p.a=clamp(p.a,0,1);
    ctx.beginPath(); ctx.arc(p.x*W,p.y*H,p.s,0,Math.PI*2);
    ctx.fillStyle=`rgba(201,168,76,${p.a*0.1*mapAlpha})`; ctx.fill();
  });

  // Land dots
  LAND.forEach(([lat,lon])=>{
    const [x,y]=proj(lat,lon);
    ctx.beginPath(); ctx.arc(x,y,1.2,0,Math.PI*2);
    ctx.fillStyle=`rgba(80,120,180,${0.22*mapAlpha})`; ctx.fill();
  });

  // Grid
  ctx.strokeStyle=`rgba(40,70,120,${0.07*mapAlpha})`; ctx.lineWidth=0.5;
  for(let lon=-180;lon<=180;lon+=30){
    ctx.beginPath(); ctx.moveTo((lon+180)/360*W,0); ctx.lineTo((lon+180)/360*W,H); ctx.stroke();
  }
  for(let lat=-60;lat<=60;lat+=30){
    ctx.beginPath(); ctx.moveTo(0,(90-lat)/180*H); ctx.lineTo(W,(90-lat)/180*H); ctx.stroke();
  }

  // ── Country outlines ──
  mexicoAlpha = t>=0.8 ? clamp((t-0.8)/1.5,0, t<8?0.7:Math.max(0,0.7-(t-8)*0.15)) : 0;
  russiaAlpha = t>=5.0 ? clamp((t-5.0)/1.5,0, t<12?0.65:Math.max(0,0.65-(t-12)*0.12)) : 0;

  drawCountry(MEXICO,'180,220,255', mexicoAlpha*mapAlpha, 'rgba(100,180,255,0.6)');
  drawCountry(RUSSIA,'255,200,120', russiaAlpha*mapAlpha, 'rgba(255,180,80,0.6)');

  // ── Light 1 (Miguel) ──
  const p1on=t>=L1[0][2];
  let pos1=null;
  if(p1on){
    pos1=getPosOnPath(L1,t);
    const [x1,y1]=proj(pos1.lat,pos1.lon);
    const a1=merged?Math.max(0,1-(mergeT-0.5)*2.5):clamp((t-L1[0][2])/0.8,0,1);
    trail1.push([x1,y1]);
    if(trail1.length>TRAIL_LEN) trail1.shift();
    trail1.forEach((pt,i)=>{
      const tf=i/trail1.length;
      ctx.beginPath(); ctx.arc(pt[0],pt[1],1.8*tf,0,Math.PI*2);
      ctx.fillStyle=`rgba(150,210,255,${tf*0.45*a1})`; ctx.fill();
    });
    if(!merged){
      drawGlow(x1,y1,70,'180,220,255',0.13*a1);
      drawGlow(x1,y1,22,'200,230,255',0.4*a1);
      drawGlow(x1,y1,6,'255,255,255',0.95*a1);
      ctx.beginPath(); ctx.arc(x1,y1,2.8,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,255,${a1})`; ctx.fill();
    }
    // city label
    if(pos1.label&&pos1.label!==lastCity&&(pos1.progress||0)>0.82){
      lastCity=pos1.label; cityLblTimer=t+1.8;
      const lbl=document.getElementById('ci-city-lbl');
      if(lbl) lbl.textContent=pos1.label;
    }
  }

  // ── Light 2 (Ekaterina) ──
  const p2on=t>=L2[0][2];
  let pos2=null;
  if(p2on){
    pos2=getPosOnPath(L2,t);
    const [x2,y2]=proj(pos2.lat,pos2.lon);
    const a2=merged?Math.max(0,1-(mergeT-0.5)*2.5):clamp((t-L2[0][2])/0.8,0,1);
    trail2.push([x2,y2]);
    if(trail2.length>TRAIL_LEN) trail2.shift();
    trail2.forEach((pt,i)=>{
      const tf=i/trail2.length;
      ctx.beginPath(); ctx.arc(pt[0],pt[1],1.8*tf,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,200,100,${tf*0.45*a2})`; ctx.fill();
    });
    if(!merged){
      drawGlow(x2,y2,70,'255,210,100',0.13*a2);
      drawGlow(x2,y2,22,'255,220,130',0.4*a2);
      drawGlow(x2,y2,6,'255,240,200',0.95*a2);
      ctx.beginPath(); ctx.arc(x2,y2,2.8,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,235,160,${a2})`; ctx.fill();
    }
  }

  // ── MERGE ──
  if(t>=14.5&&!merged){ merged=true; mergeT=0; }
  if(merged){
    mergeT=Math.min(mergeT+0.016,6);
    const [ax,ay]=proj(30.27,-97.74);
    const burstR=eio(clamp(mergeT/0.7,0,1))*Math.min(W,H)*0.4;
    const burstA=Math.max(0,1-mergeT/1.6)*0.4;
    drawGlow(ax,ay,burstR,'201,168,76',burstA);
    const orbA=clamp((mergeT-0.3)/0.5,0,1);
    drawGlow(ax,ay,100,'201,168,76',0.2*orbA);
    drawGlow(ax,ay,38,'232,213,163',0.5*orbA);
    drawGlow(ax,ay,12,'255,255,220',0.9*orbA);
    ctx.beginPath(); ctx.arc(ax,ay,4.5,0,Math.PI*2);
    ctx.fillStyle=`rgba(255,248,210,${orbA})`; ctx.fill();
  }

  // ── City label ──
  const lbl=document.getElementById('ci-city-lbl');
  if(lbl&&pos1){
    if(t<cityLblTimer&&lbl.textContent){
      const [lx,ly]=proj(pos1.lat,pos1.lon);
      lbl.style.left=(lx/W*100)+'%'; lbl.style.top=((ly-26)/H*100)+'%';
      lbl.classList.add('on');
    } else { lbl.classList.remove('on'); }
  }

  // ── TEXT EVENTS ──
  if(!showed1979&&t>=1.2){
    showed1979=true;
    const [mx,my]=proj(25.67,-100.32);
    const e=document.getElementById('ci-y1979');
    if(e){e.style.left=(mx/W*100)+'%'; e.style.top=((my-30)/H*100)+'%';}
    showEl('ci-y1979'); setTimeout(()=>hideEl('ci-y1979'),3800);
  }
  if(!showed1990&&t>=5.7){
    showed1990=true;
    const [rx,ry]=proj(56.41,61.92);
    const e=document.getElementById('ci-y1990');
    if(e){e.style.left=(rx/W*100)+'%'; e.style.top=((ry-30)/H*100)+'%';}
    showEl('ci-y1990'); setTimeout(()=>hideEl('ci-y1990'),3800);
  }
  if(!showedAustin&&t>=14.8&&merged){
    showedAustin=true;
    const [ax,ay]=proj(30.27,-97.74);
    const e=document.getElementById('ci-austin-txt');
    if(e){e.style.left=(ax/W*100)+'%'; e.style.top=((ay-48)/H*100)+'%';}
    showEl('ci-austin-txt');
  }
  if(!showedSeren&&t>=16.5){
    showedSeren=true; showEl('ci-seren');
  }
  if(!showedFinale&&t>=21.5){
    showedFinale=true;
    hideEl('ci-seren'); hideEl('ci-austin-txt');
    showEl('ci-finale');
  }
  if(t>=25) endIntro();

  /* waiting for password */
}
requestAnimationFrame(animate);

window.startCinematicIntro=function(){
  // Canvas must be visible before measuring dimensions
  requestAnimationFrame(function(){
    requestAnimationFrame(function(){
      W = cvs.width  = window.innerWidth;
      H = cvs.height = window.innerHeight;
      startTime = null;
      introEnded = false;
      showed1979=false; showed1990=false; showedAustin=false;
      showedSeren=false; showedFinale=false;
      trail1=[]; trail2=[];
      merged=false; mergeT=0;
      mexicoAlpha=0; russiaAlpha=0;
      lastCity=''; cityLblTimer=0;
      requestAnimationFrame(animate);
    });
  });
};
window.endIntro=function(){
  if(introEnded) return; introEnded=true;
  const w=document.getElementById('cinematic-intro');
  if(w){ w.classList.add('fade-out'); setTimeout(()=>{ w.style.display='none'; },2600); }
};

})();
</script>
