<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Miguel & Ekaterina — Wedding 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel:wght@400;600&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A84C;
    --gold-light: #E8D5A3;
    --gold-dark: #A07830;
    --cream: #E8E0D0;
    --white: #F5F0E8;
    --dark: #0D0D10;
    --gray: #1A1A22;
    --border: rgba(201,168,76,0.25);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'EB Garamond', serif; background: #0D0D10; color: #E8E0D0; overflow-x: hidden; }

  /* PASSWORD */
  #password-screen {
    position: fixed; inset: 0; background: var(--dark);
    display: flex; align-items: center; justify-content: center;
    z-index: 9999; flex-direction: column; gap: 1.8rem;
    transition: opacity 0.8s ease;
  }
  #password-screen.hidden { opacity: 0; pointer-events: none; }
  .pw-ornament { color: var(--gold); font-family: 'Cinzel', serif; font-size: 0.65rem; letter-spacing: 0.4em; text-transform: uppercase; }
  .pw-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 6vw, 3.5rem); font-weight: 300; color: var(--gold-light); text-align: center; letter-spacing: 0.05em; font-style: italic; }
  .pw-divider { width: 80px; height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }
  .pw-subtitle { font-family: 'Cinzel', serif; font-size: 0.6rem; letter-spacing: 0.3em; color: rgba(201,168,76,0.5); text-transform: uppercase; text-align: center; }
  .pw-input-wrap { display: flex; flex-direction: column; gap: 0.5rem; align-items: center; }
  .pw-label { font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.3em; color: rgba(201,168,76,0.6); text-transform: uppercase; }
  #pw-input { background: transparent; border: none; border-bottom: 1px solid var(--gold); color: var(--gold-light); font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; text-align: center; padding: 0.5rem 1rem; outline: none; width: 220px; letter-spacing: 0.3em; }
  #pw-input::placeholder { color: rgba(201,168,76,0.25); }
  #pw-error { color: #c97a7a; font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.2em; opacity: 0; transition: opacity 0.3s; }
  #pw-error.show { opacity: 1; }
  .pw-btn { background: transparent; border: 1px solid var(--gold); color: var(--gold); font-family: 'Cinzel', serif; font-size: 0.6rem; letter-spacing: 0.35em; text-transform: uppercase; padding: 0.85rem 2.5rem; cursor: pointer; transition: all 0.3s; }
  .pw-btn:hover { background: var(--gold); color: var(--dark); }
  .pw-hint { font-family: 'Cormorant Garamond', serif; font-style: italic; color: rgba(201,168,76,0.25); font-size: 0.8rem; }

  /* LANG */
  #lang-toggle { position: fixed; top: 1.2rem; right: 1.5rem; z-index: 100; display: flex; border: 1px solid var(--border); }
  .lang-btn { background: transparent; border: none; color: var(--gray); font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.2em; padding: 0.45rem 0.8rem; cursor: pointer; transition: all 0.3s; }
  .lang-btn.active { background: var(--gold); color: var(--dark); }

  /* NAV */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; display: flex; justify-content: center; padding: 1rem 2rem; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); border-bottom: 1px solid rgba(154,117,32,0.25); }
  .nav-links { display: flex; gap: 2rem; list-style: none; flex-wrap: wrap; justify-content: center; }
  .nav-links a { font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gray); text-decoration: none; transition: color 0.3s; }
  .nav-links a:hover { color: var(--gold-dark); }

  /* HERO */
  #hero { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 8rem 2rem 5rem; position: relative; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 20% 50%, rgba(201,168,76,0.07) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(201,168,76,0.05) 0%, transparent 50%), var(--cream); }
  .hero-corner { position: absolute; width: 100px; height: 100px; opacity: 0.2; }
  .hero-corner.tl { top: 5rem; left: 2rem; }
  .hero-corner.tr { top: 5rem; right: 2rem; transform: scaleX(-1); }
  .hero-content { position: relative; z-index: 1; }
  .hero-eyebrow { font-family: 'Cinzel', serif; font-size: 0.6rem; letter-spacing: 0.5em; color: var(--gold); text-transform: uppercase; margin-bottom: 1.5rem; animation: fadeUp 1s ease 0.2s both; }
  .hero-names { font-family: 'Cormorant Garamond', serif; font-size: clamp(3.5rem, 10vw, 7rem); font-weight: 300; color: var(--dark); line-height: 1; animation: fadeUp 1s ease 0.4s both; }
  .hero-names .amp { font-style: italic; color: var(--gold); }
  .hero-names .surname { display: block; font-size: 0.33em; letter-spacing: 0.45em; font-style: normal; color: var(--gray); margin-top: 0.6rem; font-family: 'Cinzel', serif; font-weight: 400; }
  .hero-date-row { display: flex; align-items: center; gap: 1.5rem; margin: 2rem 0; animation: fadeUp 1s ease 0.6s both; }
  .hero-date-row .hline { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent); max-width: 100px; }
  .hero-date { font-family: 'Cinzel', serif; font-size: 0.7rem; letter-spacing: 0.4em; color: #5C3D08; text-transform: uppercase; font-weight: 600; }
  .hero-loc { font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-style: italic; color: var(--gray); margin-bottom: 3rem; animation: fadeUp 1s ease 0.8s both; }

  /* COUNTDOWN */
  .countdown { display: flex; gap: 1.8rem; justify-content: center; animation: fadeUp 1s ease 1s both; margin-bottom: 3rem; }
  .cd-item { text-align: center; min-width: 65px; }
  .cd-num { font-family: 'Cormorant Garamond', serif; font-size: 2.6rem; font-weight: 300; color: var(--dark); line-height: 1; }
  .cd-lbl { font-family: 'Cinzel', serif; font-size: 0.48rem; letter-spacing: 0.3em; color: var(--gold); text-transform: uppercase; margin-top: 0.3rem; }
  .cd-sep { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--gold); align-self: flex-start; padding-top: 0.4rem; font-style: italic; }
  .scroll-hint { animation: fadeUp 1s ease 1.2s both; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; color: var(--gold); opacity: 0.5; }
  .scroll-line { width: 1px; height: 36px; background: linear-gradient(to bottom, var(--gold), transparent); animation: pulse 2s ease-in-out infinite; }
  .scroll-lbl { font-family: 'Cinzel', serif; font-size: 0.48rem; letter-spacing: 0.4em; text-transform: uppercase; }

  /* SECTIONS */
  .section-wrap { padding: 6rem 2rem; max-width: 900px; margin: 0 auto; }
  .section-wrap.full { max-width: 100%; }
  .section-inner { max-width: 900px; margin: 0 auto; }
  .sec-head { text-align: center; margin-bottom: 4rem; }
  .sec-eye { color: var(--gold); font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.5em; color: var(--gold); text-transform: uppercase; margin-bottom: 1rem; }
  .sec-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 300; font-style: italic; color: var(--dark); }
  .sec-div { display: flex; align-items: center; gap: 1rem; justify-content: center; margin-top: 1.5rem; }
  .sec-div .dl { width: 55px; height: 1px; background: linear-gradient(90deg, transparent, var(--gold)); }
  .sec-div .dr { width: 55px; height: 1px; background: linear-gradient(90deg, var(--gold), transparent); }
  .sec-div .dm { width: 6px; height: 6px; background: var(--gold); transform: rotate(45deg); }
  .sec-note { font-family: 'Cormorant Garamond', serif; font-style: italic; color: var(--gray); margin-top: 1.5rem; font-size: 1.05rem; max-width: 520px; margin-left: auto; margin-right: auto; }

  /* STORY */
  .story-tl { display: flex; flex-direction: column; gap: 3rem; position: relative; }
  .story-tl::before { content: ''; position: absolute; left: 50%; transform: translateX(-50%); top: 0; bottom: 0; width: 1px; background: linear-gradient(to bottom, transparent, var(--gold), transparent); }
  .s-item { display: grid; grid-template-columns: 1fr 60px 1fr; align-items: center; gap: 1.5rem; }
  .s-item:nth-child(odd) .s-text { text-align: right; }
  .s-item:nth-child(even) .s-text { order: 3; text-align: left; }
  .s-item:nth-child(even) .s-empty { order: 1; }
  .s-dot { width: 12px; height: 12px; background: var(--gold); border-radius: 50%; margin: 0 auto; box-shadow: 0 0 0 4px #1A1A22, 0 0 0 5px var(--gold-light); order: 2; z-index: 1; }
  .s-year { font-family: 'Cinzel', serif; font-size: 0.58rem; letter-spacing: 0.3em; color: var(--gold); text-transform: uppercase; margin-bottom: 0.4rem; }
  .s-title { font-family: 'Cormorant Garamond', serif; font-size: 1.35rem; color: var(--dark); margin-bottom: 0.4rem; }
  .s-body { font-size: 0.92rem; color: var(--gray); line-height: 1.7; }

  /* ITINERARY */
  .it-cards { display: grid; gap: 1.2rem; }
  .it-card { display: grid; grid-template-columns: 75px 1fr; gap: 1.5rem; padding: 1.5rem; border: 1px solid var(--border); background: var(--white); position: relative; overflow: hidden; transition: border-color 0.3s; }
  .it-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--gold), var(--gold-light)); }
  .it-card:hover { border-color: var(--gold); }
  .it-time { font-family: 'Cinzel', serif; font-size: 0.6rem; letter-spacing: 0.15em; color: var(--gold); text-align: center; padding-top: 0.2rem; }
  .it-title { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; color: var(--dark); margin-bottom: 0.25rem; }
  .it-desc { font-size: 0.88rem; color: var(--gray); line-height: 1.6; }

  /* RSVP */
  .rsvp-box { background: var(--white); border: 1px solid var(--border); padding: 3rem; max-width: 580px; margin: 0 auto; position: relative; }
  .rsvp-box::before, .rsvp-box::after { content: ''; position: absolute; width: 28px; height: 28px; border-color: var(--gold); border-style: solid; }
  .rsvp-box::before { top: 10px; left: 10px; border-width: 1px 0 0 1px; }
  .rsvp-box::after { bottom: 10px; right: 10px; border-width: 0 1px 1px 0; }
  .f-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .f-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
  .f-lbl { font-family: 'Cinzel', serif; font-size: 0.52rem; letter-spacing: 0.3em; color: var(--gold-dark); text-transform: uppercase; }
  .f-input, .f-sel, .f-ta { background: var(--cream); border: 1px solid var(--border); border-bottom: 1px solid var(--gold); color: var(--dark); font-family: 'EB Garamond', serif; font-size: 1rem; padding: 0.6rem 0.8rem; outline: none; transition: all 0.3s; width: 100%; }
  .f-input:focus, .f-sel:focus, .f-ta:focus { background: var(--white); border-color: var(--gold); }
  .f-ta { resize: vertical; min-height: 75px; }
  .radio-g { display: flex; gap: 1.5rem; padding: 0.4rem 0; }
  .radio-o { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; }
  .radio-o input { accent-color: var(--gold); }
  .radio-o span { font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.15em; color: var(--gray); }
  .sub-btn { width: 100%; background: var(--dark); border: none; color: var(--gold-light); font-family: 'Cinzel', serif; font-size: 0.6rem; letter-spacing: 0.4em; text-transform: uppercase; padding: 1.1rem 2rem; cursor: pointer; transition: all 0.3s; margin-top: 0.8rem; }
  .sub-btn:hover { background: var(--gold); color: var(--dark); }
  .rsvp-ok { text-align: center; display: none; padding: 2rem; }
  .rsvp-ok .ok-icon { font-size: 3rem; margin-bottom: 1rem; }
  .rsvp-ok p { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-style: italic; color: var(--dark); }

  /* GIFTS */
  .gifts-g { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 1.5rem; }
  .gift-c { border: 1px solid var(--border); padding: 2rem 1.5rem; text-align: center; background: var(--white); transition: all 0.3s; cursor: pointer; }
  .gift-c:hover { border-color: var(--gold); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(201,168,76,0.1); }
  .gift-ico { font-size: 2rem; margin-bottom: 1rem; }
  .gift-n { font-family: 'Cinzel', serif; font-size: 0.6rem; letter-spacing: 0.28em; color: var(--dark); text-transform: uppercase; margin-bottom: 0.5rem; }
  .gift-d { font-size: 0.85rem; color: var(--gray); line-height: 1.5; }

  /* HOTELS */
  .hotels-g { display: grid; grid-template-columns: repeat(auto-fit, minmax(255px, 1fr)); gap: 1.5rem; }
  .hotel-c { border: 1px solid var(--border); background: var(--white); overflow: hidden; transition: border-color 0.3s; }
  .hotel-c:hover { border-color: var(--gold); }
  .hotel-h { background: var(--dark); padding: 1.5rem; }
  .hotel-stars { color: var(--gold); font-size: 0.75rem; margin-bottom: 0.3rem; }
  .hotel-n { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; color: var(--gold-light); font-style: italic; }
  .hotel-b { padding: 1.5rem; }
  .hotel-d { display: flex; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.55rem; }
  .hotel-d .hi { color: var(--gold); font-size: 0.85rem; flex-shrink: 0; }
  .hotel-d span { font-size: 0.86rem; color: var(--gray); line-height: 1.4; }
  .hotel-badge { display: inline-block; background: rgba(201,168,76,0.08); border: 1px solid var(--border); color: var(--gold-dark); font-family: 'Cinzel', serif; font-size: 0.48rem; letter-spacing: 0.2em; padding: 0.3rem 0.7rem; text-transform: uppercase; margin-top: 0.5rem; }

  /* AIRPORTS */
  .apt-g { display: grid; grid-template-columns: repeat(auto-fit, minmax(255px, 1fr)); gap: 1.5rem; }
  .apt-c { border: 1px solid var(--border); background: var(--white); padding: 2rem; position: relative; overflow: hidden; }
  .apt-c::after { content: '✈'; position: absolute; right: 1.2rem; top: 1.2rem; font-size: 1.5rem; color: var(--gold); opacity: 0.25; }
  .apt-code { font-family: 'Cinzel', serif; font-size: 2rem; color: var(--gold); letter-spacing: 0.1em; margin-bottom: 0.2rem; }
  .apt-name { font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; color: var(--dark); margin-bottom: 1rem; font-style: italic; }
  .apt-d { font-size: 0.87rem; color: var(--gray); line-height: 1.6; margin-bottom: 0.35rem; }
  .apt-d strong { color: var(--dark); font-weight: 400; font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.2em; text-transform: uppercase; }
  .shuttle-box { margin-top: 2.5rem; border: 1px solid var(--border); background: var(--cream); padding: 2rem; }
  .shuttle-title { font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.3em; color: var(--gold); text-transform: uppercase; margin-bottom: 1rem; }
  .shuttle-body { font-size: 0.92rem; color: var(--gray); line-height: 1.7; }

  /* FOOTER */
  footer { text-align: center; padding: 4rem 2rem; background: var(--dark); border-top: 1px solid rgba(201,168,76,0.15); }
  .ft-names { font-family: 'Cormorant Garamond', serif; font-size: 2.4rem; font-weight: 300; font-style: italic; color: var(--gold-light); }
  .ft-surname { font-family: 'Cinzel', serif; font-size: 0.52rem; letter-spacing: 0.45em; color: rgba(201,168,76,0.35); margin-top: 0.25rem; text-transform: uppercase; }
  .ft-line { width: 55px; height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent); margin: 1.5rem auto; }
  .ft-date { font-family: 'Cinzel', serif; font-size: 0.58rem; letter-spacing: 0.38em; color: rgba(201,168,76,0.4); text-transform: uppercase; }
  .ft-love { font-family: 'Cormorant Garamond', serif; font-style: italic; color: rgba(201,168,76,0.2); font-size: 0.82rem; margin-top: 2rem; }

  /* WHITE BG SECTION */
  .white-bg { background: var(--white); }

  /* LANG */
  [data-lang="ru"] { display: none; }
  body.lang-ru [data-lang="en"] { display: none; }
  body.lang-ru [data-lang="ru"] { display: block; }
  body.lang-ru span[data-lang="ru"] { display: inline; }
  body.lang-ru span[data-lang="en"] { display: none; }

  /* ANIMATIONS */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes pulse { 0%,100% { opacity: 0.6; } 50% { opacity: 0.2; } }
  .fi { opacity: 0; transform: translateY(18px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .fi.vis { opacity: 1; transform: translateY(0); }

  @media (max-width: 640px) {
    nav { display: none; }
    .story-tl::before { left: 18px; }
    .s-item { grid-template-columns: 36px 1fr; }
    .s-dot { order: 1; margin: 0; }
    .s-text { order: 2; text-align: left !important; }
    .s-empty { display: none; }
    .f-row { grid-template-columns: 1fr; }
    .countdown { gap: 1rem; }
    .cd-num { font-size: 2rem; }
    .rsvp-box { padding: 2rem 1.2rem; }
  }
